# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must always use LF
*.sh text eol=lf

# Go source files
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# Web files
*.vue text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Windows batch scripts need CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
